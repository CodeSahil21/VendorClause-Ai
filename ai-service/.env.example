# LlamaParse API
LLAMA_CLOUD_API_KEY=your-llama-parse-api-key-here

# Redis (for BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=gateway_redis_pass_2024

# PostgreSQL
DATABASE_URL=postgresql://gateway_user:gateway_secure_pass_2024@localhost:5432/gateway_db

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents
MINIO_USE_SSL=false

# Qdrant
QDRANT_URL=http://localhost:6333

# Ollama
OLLAMA_URL=http://localhost:11434

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# Langfuse
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_BASE_URL=http://localhost:3040
# Optional legacy fallback for older SDK paths
LANGFUSE_HOST=http://localhost:3040

# LangGraph Checkpointing (MongoDB)
CHECKPOINT_BACKEND=mongodb
# Use localhost when ai-service runs on host machine.
MONGODB_URL=mongodb://langgraph:langgraph_pass_2024@localhost:27017/?authSource=admin
# Use this instead when ai-service runs inside Docker on the same compose network:
# MONGODB_URL=mongodb://langgraph:langgraph_pass_2024@mongodb:27017/?authSource=admin
MONGODB_DATABASE=langgraph
MONGODB_CHECKPOINT_COLLECTION=checkpoints

# Mem0 (optional long-term memory)
MEM0_API_KEY=
